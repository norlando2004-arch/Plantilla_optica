APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Admin panel (Basic Auth)
# In local, if you leave these empty, /admin will be accessible without auth.
ADMIN_USER=
ADMIN_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

# --- PostgreSQL (hosted) ---
# If your provider gives you a connection string, prefer DB_URL:
# DB_CONNECTION=pgsql
# DB_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# Or use individual fields:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120

# OCR (para analizar fórmulas desde imágenes/PDF escaneados)
# Si en Windows no queda en PATH, puedes setear la ruta completa al ejecutable.
TESSERACT_BINARY=

# Directorio con idiomas (*.traineddata). Útil para agregar spa.traineddata sin tocar Program Files.
TESSERACT_TESSDATA_DIR=

# OCR en PDFs escaneados requiere convertir PDF→imagen (primera página)
PDFTOPPM_BINARY=
PDFTOPNG_BINARY=
MAGICK_BINARY=
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
HERO_BANNERS_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# En producción puedes dejar HERO_BANNERS_DISK=public si tu servidor conserva storage/
# o cambiarlo a s3 para persistencia entre despliegues en Render.

VITE_APP_NAME="${APP_NAME}"

# --- Pagos ---
# Driver de pagos: dummy | bold
PAGOS_DRIVER=dummy

# --- Bold (API Link de pagos) ---
PAGOS_BOLD_ENABLED=false
BOLD_IDENTITY_KEY=

# Base URL (por defecto integraciones)
BOLD_BASE_URL=https://integrations.api.bold.co
BOLD_TIMEOUT_SECONDS=20
# Solo para local cuando PHP/cURL no tiene CA certificates correctamente configurados.
BOLD_VERIFY_SSL=true

# Webhook secret (en sandbox puede venir vacío)
BOLD_WEBHOOK_SECRET=

# Callback de retorno (si no lo defines, se usa /pagos/retorno/bold)
# IMPORTANTE: Bold normalmente requiere https. En local puedes permitir http con:
BOLD_ALLOW_INSECURE_CALLBACK=true
# BOLD_CALLBACK_URL=https://tudominio.com/pagos/retorno/bold
